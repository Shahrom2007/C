#include <stdio.h>
#include <stdlib.h>
#include "matrix.h"

int main() {
    int matrix_size;
    double **resulting_matrix = NULL;

    
    printf("Enter matrix size:\n");
    scanf("%d", &matrix_size);
    
    // matrix_1
    double **matrix_1 = (double**)malloc(matrix_size * sizeof(double*));
    for (int i = 0; i < matrix_size; i++) {
        matrix_1[i] = (double*)malloc(matrix_size * sizeof(double));
    }
    
    printf("Enter numbers for your matrix_1\n");
    for (int i = 0; i < matrix_size; i++) {
        for (int j = 0; j < matrix_size; j++) {
            printf("Element - [%d][%d]: ", i, j);
            scanf("%lf", &matrix_1[i][j]);
        }
    }
    
    printf("Your matrix_1:\n");
    for (int i = 0; i < matrix_size; i++) {
        for (int j = 0; j < matrix_size; j++) {
            printf("%.2f\t", matrix_1[i][j]);
        }
        printf("\n");
    }
    
    //matrix_2
    double **matrix_2 = (double**)malloc(matrix_size * sizeof(double*));
    for (int i = 0; i < matrix_size; i++) {
        matrix_2[i] = (double*)malloc(matrix_size * sizeof(double));
    }
    
    printf("\nEnter numbers for your matrix_2\n");
    for (int i = 0; i < matrix_size; i++) {
        for (int j = 0; j < matrix_size; j++) {
            printf("Element - [%d][%d]: ", i, j);
            scanf("%lf", &matrix_2[i][j]);
        }
    }
    
    printf("Your matrix_2:\n");
    for (int i = 0; i < matrix_size; i++) {
        for (int j = 0; j < matrix_size; j++) {
            printf("%.2f\t", matrix_2[i][j]);
        }
        printf("\n");
    }
    
    // +, -, *
    printf("\n+, -, *?\n");
    char operation;
    scanf(" %c", &operation);
    
    switch (operation) {
        case '*':
            resulting_matrix = multiply(matrix_size, matrix_1, matrix_2);
            break;
        case '+':
            resulting_matrix = add(matrix_size, matrix_1, matrix_2);
            break;
        case '-':
            resulting_matrix = subtract(matrix_size, matrix_1, matrix_2);
            break;
        default:
            printf("Invalid operation!\n");
            return 1;
    }
    

    printf("Result:\n");
        for (int i = 0; i < matrix_size; i++) {
            printf("\n");
            for (int j = 0; j < matrix_size; j++) {
                printf("%lf\t", resulting_matrix[i][j]);
            }
        }
        printf("\n");
    
    // освобождение памяти
    for (int i = 0; i < matrix_size; i++) free(matrix_1[i]);
    free(matrix_1);
    
    for (int i = 0; i < matrix_size; i++) free(matrix_2[i]);
    free(matrix_2);
    
    for (int i = 0; i < matrix_size; i++) free(resulting_matrix[i]);
    free(resulting_matrix);
    
    return 0;
}
