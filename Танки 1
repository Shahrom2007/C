def cross_product(a, b, c):
    """Вычисляет векторное произведение для определения положения точки относительно прямой."""
    return (b[0] - a[0]) * (c[1] - a[1]) - (b[1] - a[1]) * (c[0] - a[0])

def is_separated(poly1, poly2):
    """Проверяет, можно ли провести разделяющую линию по сторонам первого многоугольника."""
    n = len(poly1)
    for i in range(n):
        a = poly1[i]
        b = poly1[(i + 1) % n]
        
        # Если все точки второго многоугольника лежат «снаружи» стороны первого
        if all(cross_product(a, b, p) > 0 for p in poly2):
            return True
    return False

def check_collision(tank1, tank2):
    """Танки пересекаются, если ни для одного из них нельзя найти разделяющую ось."""
    return not is_separated(tank1, tank2) and not is_separated(tank2, tank1)

def get_input(name):
    print(f"Введите координаты 4 точек для {name} (в формате x y через пробел):")
    points = []
    for i in range(4):
        while True:
            try:
                coords = input(f"Точка {i+1}: ").split()
                x, y = map(float, coords)
                if 0 <= x <= 10 and 0 <= y <= 10:
                    points.append((x, y))
                    break
                else:
                    print("Ошибка: Координаты должны быть в диапазоне от 0 до 10.")
            except ValueError:
                print("Ошибка: Введите два числа через пробел.")
    return points

# Основной цикл программы
def main():
    tank_a = get_input("Танка А")
    tank_b = get_input("Танка Б")

    if check_collision(tank_a, tank_b):
        print("\nРезультат: ТАНКИ ПЕРЕСЕКАЮТСЯ!")
    else:
        print("\nРезультат: Столкновения нет.")

if __name__ == "__main__":
    main()
